generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Kelas {
  id        String   @id @default(cuid())
  nama      String
  createdAt DateTime @default(now())
  materi    Materi[]
}

model Materi {
  id          String   @id @default(cuid())
  judul       String
  slug        String   @unique
  deskripsi   String?
  content     String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  kelasId     String
  kelas       Kelas    @relation(fields: [kelasId], references: [id])
}

model Blog {
  id          String   @id @default(cuid())
  judul       String
  slug        String   @unique
  deskripsi   String?
  content     String
  tags        String[]
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}